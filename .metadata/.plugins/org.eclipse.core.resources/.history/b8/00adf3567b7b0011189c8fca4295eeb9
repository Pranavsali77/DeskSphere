package com.ithelpdesk.backend.service;

import java.time.LocalDateTime;
import java.util.List;

import org.springframework.stereotype.Service;

import com.ithelpdesk.backend.dto.FeedbackRequest;
import com.ithelpdesk.backend.dto.FeedbackResponse;
import com.ithelpdesk.backend.entity.Feedback;
import com.ithelpdesk.backend.repository.FeedbackRepository;

@Service
public class EmployeeFeedbackServiceImpl implements EmployeeFeedbackService {

	private final FeedbackRepository feedbackRepository;
	private final TicketRepository ticketRepository;

	public EmployeeFeedbackServiceImpl(
	        FeedbackRepository feedbackRepository,
	        TicketRepository ticketRepository) {

	    this.feedbackRepository = feedbackRepository;
	    this.ticketRepository = ticketRepository;
	}
    @Override
    public FeedbackResponse submitFeedback(FeedbackRequest request) {

        Feedback feedback = new Feedback();
        feedback.setRating(request.getRating());
        feedback.setComment(request.getComment());
        feedback.setCreatedAt(LocalDateTime.now());

        feedback = feedbackRepository.save(feedback);

        FeedbackResponse response = new FeedbackResponse();
        response.setId(feedback.getId());
        response.setRating(feedback.getRating());
        response.setComment(feedback.getComment());

        return response;
    }

    @Override
    public List<FeedbackResponse> getAllFeedback() {

        return feedbackRepository.findAll()
                .stream()
                .map(feedback -> {
                    FeedbackResponse response = new FeedbackResponse();
                    response.setId(feedback.getId());
                    response.setRating(feedback.getRating());
                    response.setComment(feedback.getComment());
                    return response;
                })
                .toList();
    }

    @Override
    public List<FeedbackResponse> getEngineerFeedback(Long engineerId) {
        return null;
    }
}